---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
const { title, description, post = false } = Astro.props;
const base = import.meta.env.BASE_URL;

const social = {
  github: 'https://github.com/reginaldosilva27',
  linkedin: 'https://www.linkedin.com/in/reginaldosilva27/',
  youtube: 'https://www.youtube.com/@dadosemacao',
};
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32.png`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <meta name="theme-color" content="#1a1a1f" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={post ? 'article' : 'website'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    {post && <div class="progress" id="progress"></div>}
    <div class="grain" aria-hidden="true"></div>

    <header class="site-header">
      <a href={base} class="brand">
        <span class="brand-dot"></span>
        <span class="brand-text">data<span class="brand-slash">/</span>in<span class="brand-slash">/</span>action</span>
      </a>
      <nav class="site-nav">
        <a href={base} class="nav-link">Blog</a>
        <a href={`${base}sobre/`} class="nav-link">Sobre</a>
        <span class="nav-divider" aria-hidden="true"></span>
        <a class="icon-link" href={social.github} target="_blank" rel="noopener" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>
        </a>
        <a class="icon-link" href={social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"/></svg>
        </a>
        <a class="icon-link" href={social.youtube} target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8ZM9.6 15.6V8.4l6.2 3.6-6.2 3.6Z"/></svg>
        </a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-grid">
        <div>
          <div class="footer-mark">data<span class="brand-slash">/</span>in<span class="brand-slash">/</span>action</div>
          <p>Dados e IA na prática. Databricks, Azure, RAG e agentes de IA.</p>
          <p class="footer-fine">Por Reginaldo Silva · site estático em Astro, publicado no GitHub Pages.</p>
        </div>
        <div class="footer-links">
          <a href={base}>Blog</a>
          <a href={`${base}sobre/`}>Sobre mim</a>
          <a href={social.youtube} target="_blank" rel="noopener">YouTube</a>
          <a href={social.github} target="_blank" rel="noopener">GitHub</a>
          <a href={social.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </div>
    </footer>

    {post && (
      <script is:inline>
        (() => {
          const bar = document.getElementById('progress');
          if (!bar) return;
          const update = () => {
            const h = document.documentElement;
            const max = h.scrollHeight - h.clientHeight;
            bar.style.transform = `scaleX(${max > 0 ? h.scrollTop / max : 0})`;
          };
          update();
          document.addEventListener('scroll', update, { passive: true });
        })();
      </script>
    )}

    <!-- YouTube facade: thumbnail vira iframe só ao clicar (performance) -->
    <script is:inline>
      (() => {
        const wire = () => {
          document.querySelectorAll('.yt-facade:not([data-wired])').forEach((el) => {
            el.setAttribute('data-wired', '1');
            el.addEventListener('click', () => {
              const id = el.getAttribute('data-id');
              if (!id) return;
              const f = document.createElement('iframe');
              f.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
              f.title = el.getAttribute('data-title') || 'YouTube';
              f.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
              f.allowFullscreen = true;
              f.loading = 'lazy';
              el.replaceChildren(f);
              el.classList.add('is-playing');
            });
          });
        };
        wire();
        document.addEventListener('astro:page-load', wire);
      })();
    </script>
  </body>
</html>
