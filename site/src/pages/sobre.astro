---
import Base from '../layouts/Base.astro';

const social = {
  github: 'https://github.com/reginaldosilva27',
  linkedin: 'https://www.linkedin.com/in/reginaldosilva27/',
  youtube: 'https://www.youtube.com/@dadosemacao',
};

const stacks = [
  { label: 'IA / ML', items: ['LangGraph', 'LangSmith', 'MCP', 'Claude', 'OpenAI', 'Azure OpenAI', 'AWS Bedrock', 'Vertex AI', 'RAG'] },
  { label: 'Linguagens', items: ['Python', 'TypeScript', 'SQL', 'T-SQL', 'PySpark', 'C#', 'PowerShell'] },
  { label: 'Plataformas de Dados', items: ['Databricks', 'Delta Lake', 'Spark', 'Kafka', 'Airflow', 'dbt'] },
  { label: 'Cloud & Bancos', items: ['Azure', 'AWS', 'GCP', 'SQL Server', 'PostgreSQL', 'MongoDB', 'BigQuery', 'Snowflake', 'Redshift'] },
];

const journey = [
  'Técnico de redes',
  'DBA SQL Server',
  'Business Intelligence',
  'Cloud',
  'Lakehouse',
  'AI Engineering',
];

const projects = [
  { name: 'AI Agent Simulator', desc: 'Ferramenta visual pra entender Agent Harness, RAG/RAGLess e DeepAgents na prática.' },
  { name: 'dtstools', desc: 'Biblioteca Python (PyPI) de manutenção de tabelas Delta Lake.' },
  { name: 'databricks_0_100', desc: 'Templates de infraestrutura e a série "Databricks 0 a 100".' },
  { name: 'CrewAI experiments', desc: 'Agentes inteligentes gerando código, docs e assessments.' },
];
---
<Base title="Sobre · Reginaldo Silva | DataInAction" description="AI Engineer e Senior Data Engineer & Architect com 13+ anos em dados. Construindo agentes de IA e plataformas de dados prontas para produção.">
  <article class="about">
    <a class="back" href={import.meta.env.BASE_URL}>← Voltar ao blog</a>

    <section class="about-hero">
      <p class="post-eyebrow">Sobre mim</p>
      <h1>Reginaldo Silva</h1>
      <p class="about-role">AI Engineer · Senior Data Engineer &amp; Architect</p>
      <p class="about-lead">
        Construo agentes de IA e plataformas de dados prontas para produção. São <b>13+ anos</b> em
        engenharia de dados, hoje como <b>AI Engineer na Belake.ai (Dataside)</b>, escrevendo aqui no
        blog e ensinando no canal <a href={social.youtube} target="_blank" rel="noopener">@dadosemacao</a>.
      </p>
      <div class="about-actions">
        <a class="btn btn-primary" href={social.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a class="btn btn-ghost" href={social.github} target="_blank" rel="noopener">GitHub</a>
        <a class="btn btn-ghost" href={social.youtube} target="_blank" rel="noopener">YouTube</a>
      </div>
    </section>

    <section class="about-section">
      <h2>Filosofia</h2>
      <p>
        IA de qualidade depende de uma fundação de dados bem arquitetada. Na era da IA, os
        fundamentos de engenharia de software ficam ainda mais relevantes, e a escolha de
        ferramentas deve ser sempre contextual, não a busca cega pela "melhor" opção.
      </p>
      <p>
        Foco atual: <b>engenharia de agentes de IA de ponta a ponta</b>: arquitetura, orquestração,
        deploy e observabilidade. Stack TypeScript/Node no backend, React + Vite no frontend e Python
        na camada de IA, com práticas de TDD e SDD, usando Claude Code, Cursor e Codex no dia a dia.
      </p>
    </section>

    <section class="about-section">
      <h2>Trajetória</h2>
      <div class="journey">
        {journey.map((step, i) => (
          <>
            <span class="journey-step">{step}</span>
            {i < journey.length - 1 && <span class="journey-arrow">→</span>}
          </>
        ))}
      </div>
    </section>

    <section class="about-section">
      <h2>Stack</h2>
      <div class="stack-grid">
        {stacks.map((s) => (
          <div class="stack-card">
            <h3>{s.label}</h3>
            <div class="stack-tags">
              {s.items.map((it) => <span class="tag">{it}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="about-section">
      <h2>Projetos</h2>
      <div class="proj-grid">
        {projects.map((p) => (
          <div class="proj-card">
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="about-section">
      <h2>Comunidade</h2>
      <p>
        Palestrante em <b>Microsoft AI Tour</b>, <b>SQL Saturday</b>, <b>Data&amp;AI</b> e
        <b> Azure Bootcamp</b>. Ativo no LinkedIn com 7k+ seguidores e produzindo conteúdo técnico
        no blog e no YouTube.
      </p>
      <div class="about-actions">
        <a class="btn btn-primary" href={social.youtube} target="_blank" rel="noopener">Inscreva-se no canal</a>
        <a class="btn btn-ghost" href={social.linkedin} target="_blank" rel="noopener">Conecte no LinkedIn</a>
      </div>
    </section>

    <a class="back" href={import.meta.env.BASE_URL} style="margin-top:48px">← Voltar ao blog</a>
  </article>
</Base>
