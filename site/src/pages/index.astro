---
import Base from '../layouts/Base.astro';
import posts from '../data/posts.json';

const base = import.meta.env.BASE_URL;
const sorted = [...posts].sort((a, b) => (b.date ?? '').localeCompare(a.date ?? ''));
const fmt = (d) => (d ? new Date(d).toLocaleDateString('pt-BR') : '');
---
<Base title="Blog" description="Posts migrados do Wix">
  <h1>Posts</h1>
  <ul class="post-list">
    {sorted.map((p) => (
      <li>
        <a class="card" href={`${base}blog/${p.slug}/`}>
          {p.cover && <img src={`${base}${p.cover}`} alt={p.title} loading="lazy" />}
          <div class="card-body">
            <div class="card-meta">{fmt(p.date)} · {p.minutesToRead ?? '?'} min</div>
            <h2>{p.title}</h2>
            <p>{p.excerpt}</p>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Base>
